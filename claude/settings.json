{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git init)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(ls *)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x *)",
      "Bash(jq *)",
      "Bash(command -v *)",
      "Bash(gibo dump *)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(sudo *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.ssh/*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(~/.ssh/*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/brian/.claude/hooks/discord-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/brian/.claude/hooks/discord-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "language": "日本語"
}
